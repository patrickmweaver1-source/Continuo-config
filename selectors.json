{
  "version": 4,
  "note": "ALLOWLIST ONLY. AIdentity activates on these LLM agent sites and nowhere else. Passive descriptive config only \u2014 NO logic, prompts, or user data here.",
  "sites": {
    "chatgpt": {
      "hosts": [
        "chatgpt.com",
        "chat.openai.com"
      ],
      "label": "ChatGPT",
      "input": "#prompt-textarea, div[contenteditable='true'].ProseMirror, textarea[data-testid='prompt-textarea']",
      "userMessage": "[data-message-author-role='user']",
      "assistantMessage": "[data-message-author-role='assistant']",
      "messageText": ".markdown, .whitespace-pre-wrap",
      "active": true,
      "interface": {
        "markup": "markdown",
        "channel": "weak",
        "ctx_hint": 420
      }
    },
    "claude": {
      "hosts": [
        "claude.ai"
      ],
      "label": "Claude",
      "input": "div[contenteditable='true'].ProseMirror, div[contenteditable='true'][aria-label]",
      "userMessage": "[data-testid='user-message'], div[data-testid='user-message']",
      "assistantMessage": "[data-testid='assistant-message'], .font-claude-message",
      "messageText": ".font-claude-message, [data-testid='user-message']",
      "active": true,
      "interface": {
        "markup": "xml",
        "channel": "weak",
        "ctx_hint": 420
      }
    },
    "gemini": {
      "hosts": [
        "gemini.google.com"
      ],
      "label": "Gemini",
      "input": "rich-textarea div[contenteditable='true'], .ql-editor",
      "userMessage": "user-query, .user-query-bubble-with-background",
      "assistantMessage": "message-content, .model-response-text",
      "messageText": "message-content, .model-response-text, .query-text",
      "active": true,
      "interface": {
        "markup": "markdown",
        "channel": "weak",
        "ctx_hint": 420
      }
    },
    "grok": {
      "hosts": [
        "grok.com"
      ],
      "label": "Grok",
      "input": "textarea, div[contenteditable='true']",
      "userMessage": ".message-bubble.user, [data-testid='user-message']",
      "assistantMessage": ".message-bubble.assistant, .response-content-markdown",
      "messageText": ".message-bubble, .response-content-markdown",
      "active": true,
      "interface": {
        "markup": "markdown",
        "channel": "weak",
        "ctx_hint": 220
      }
    },
    "copilot": {
      "hosts": [
        "copilot.microsoft.com"
      ],
      "label": "Copilot",
      "input": "textarea#userInput, div[contenteditable='true']",
      "userMessage": "[data-content='user-message']",
      "assistantMessage": "[data-content='ai-message']",
      "messageText": "[data-content]",
      "active": true,
      "interface": {
        "markup": "markdown",
        "channel": "weak",
        "ctx_hint": 320
      }
    },
    "deepseek": {
      "hosts": [
        "chat.deepseek.com"
      ],
      "label": "DeepSeek",
      "input": "textarea#chat-input, div[contenteditable='true']",
      "userMessage": ".fbb737a4",
      "assistantMessage": ".ds-markdown",
      "messageText": ".ds-markdown, .fbb737a4",
      "active": true,
      "interface": {
        "markup": "markdown",
        "channel": "weak",
        "ctx_hint": 220
      }
    },
    "cocounsel": {
      "hosts": [
        "cocounsel.thomsonreuters.com",
        "app.cocounsel.com"
      ],
      "label": "CoCounsel",
      "input": "textarea, div[contenteditable='true']",
      "userMessage": "[data-role='user']",
      "assistantMessage": "[data-role='assistant']",
      "messageText": "[data-role]",
      "active": true,
      "interface": {
        "markup": "markdown",
        "channel": "weak",
        "ctx_hint": 320
      }
    },
    "localmodels": {
      "hosts": [
        "localhost",
        "127.0.0.1"
      ],
      "label": "Local model",
      "local": true,
      "active": true,
      "input": "textarea, div[contenteditable='true'], #chat-input",
      "userMessage": ".user-message, [data-role='user'], .chat-user",
      "assistantMessage": ".assistant-message, [data-role='assistant'], .chat-assistant, .markdown-body",
      "messageText": ".markdown-body, [data-role], .message-content",
      "interface": {
        "markup": "markdown",
        "channel": "weak",
        "ctx_hint": 420
      }
    }
  },
  "min_extension_version": "0.2.0",
  "notice": ""
}